# Visual Studio 2015 user specific files
.vs/
.vsconfig
.idea/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/*/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Whitelist bundled PSO pipeline caches. These are a build INPUT (the cook bundles them),
# recorded from gameplay and not reproducible in CI, so they are versioned. The directory
# must be re-included before the files. See planning/docs/Improvements/PSO-Shader-Warmup.md.
!Build/*/PipelineCaches/
!Build/*/PipelineCaches/*.spc

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/*/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*

# Game build files
Platforms/*
*.cpp~

#bash scripts
deleteprojectfiles.txt
/Windows

# Simulator
Simulator/out/*
Simulator/out_sr/*
Simulator/token.json

# Claude Code local settings (machine-specific, never commit)
.claude/settings.local.json
# Package script local config — machine-specific paths, never commit
Scripts/package/package-config.local.json

# Claude Code session state and logs (ephemeral, never commit)
planning/production/session-state/
planning/production/session-logs/
/Plugins/UnrealClaude

# LLM wiki — incremental update tracking (machine-local, never commit)
planning/production/wiki/.pending-update.md

# Obsidian vault settings (machine-specific, never commit)
.obsidian/
GEMINI.md
/.gemini
AGENTS.md

# HierarchicalNavMesh baked data (generated, never commit)
*.hnav

steamdeveloper/

# Python bytecode cache (sim harness, generated)
__pycache__/
*.pyc
Config/DefaultEngine.ini
